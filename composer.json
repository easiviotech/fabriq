{
    "name": "fabrq/fabriq",
    "description": "Fabriq — Unified Swoole-powered application platform. Serves HTTP APIs, WebSocket realtime, per-tenant frontend builds, background jobs, and event bus — with optional add-ons for live streaming and game server.",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-swoole": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "suggest": {
        "rybakit/msgpack": "Required when gaming package is enabled (MessagePack UDP protocol)"
    },
    "replace": {
        "fabriq/kernel": "self.version",
        "fabriq/storage": "self.version",
        "fabriq/observability": "self.version",
        "fabriq/tenancy": "self.version",
        "fabriq/streaming": "self.version",
        "fabriq/gaming": "self.version"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Fabriq\\Kernel\\": "packages/kernel/src/",
            "Fabriq\\Tenancy\\": "packages/tenancy/src/",
            "Fabriq\\Storage\\": "packages/storage/src/",
            "Fabriq\\Http\\": "packages/http/src/",
            "Fabriq\\Realtime\\": "packages/realtime/src/",
            "Fabriq\\Queue\\": "packages/queue/src/",
            "Fabriq\\Events\\": "packages/events/src/",
            "Fabriq\\Security\\": "packages/security/src/",
            "Fabriq\\Observability\\": "packages/observability/src/",
            "Fabriq\\Streaming\\": "packages/streaming/src/",
            "Fabriq\\Gaming\\": "packages/gaming/src/",
            "Fabriq\\Orm\\": "packages/orm/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fabriq\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
