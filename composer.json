{
    "name": "fabrq/swoolefabric",
    "description": "SwooleFabric — Unified Swoole-powered backend platform with multi-tenancy, realtime, queue, events, security, and observability.",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-swoole": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "SwooleFabric\\Kernel\\": "packages/kernel/src/",
            "SwooleFabric\\Tenancy\\": "packages/tenancy/src/",
            "SwooleFabric\\Storage\\": "packages/storage/src/",
            "SwooleFabric\\Http\\": "packages/http/src/",
            "SwooleFabric\\Realtime\\": "packages/realtime/src/",
            "SwooleFabric\\Queue\\": "packages/queue/src/",
            "SwooleFabric\\Events\\": "packages/events/src/",
            "SwooleFabric\\Security\\": "packages/security/src/",
            "SwooleFabric\\Observability\\": "packages/observability/src/",
            "SwooleFabric\\ExampleChat\\": "apps/example-chat/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SwooleFabric\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}