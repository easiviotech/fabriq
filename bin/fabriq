<?php

declare(strict_types=1);

/**
 * Fabriq CLI Entry Point
 *
 * Usage:
 *   php bin/fabriq serve       — Start HTTP + WS server
 *   php bin/fabriq worker      — Start queue consumers
 *   php bin/fabriq scheduler   — Start scheduler
 *
 * All commands load the application via bootstrap/app.php,
 * which registers service providers from config/app.php.
 */

require_once __DIR__ . '/../vendor/autoload.php';

use Fabriq\Kernel\Application;
use Fabriq\Kernel\Config;
use Fabriq\Storage\DbManager;
use Fabriq\Queue\Consumer;
use Fabriq\Queue\IdempotencyStore;
use Fabriq\Queue\Scheduler;
use Fabriq\Events\EventConsumer;

$command = $argv[1] ?? 'help';

switch ($command) {
    case 'serve':
        echo "╔══════════════════════════════════════╗\n";
        echo "║              Fabriq                  ║\n";
        echo "║   Unified Swoole Runtime Platform    ║\n";
        echo "╚══════════════════════════════════════╝\n\n";

        /** @var Application $app */
        $app = require __DIR__ . '/../bootstrap/app.php';
        $app->run();
        break;

    case 'worker':
        echo "╔══════════════════════════════════════╗\n";
        echo "║              Fabriq                  ║\n";
        echo "║           Queue Worker               ║\n";
        echo "╚══════════════════════════════════════╝\n\n";

        $basePath = dirname(__DIR__);
        $config = Config::fromDirectory($basePath . '/config');
        $dbManager = new DbManager();

        // Boot must happen inside a coroutine context for Swoole
        \Swoole\Coroutine\run(function () use ($config, $dbManager, $basePath) {
            $dbManager->boot($config);

            $idempotencyStore = new IdempotencyStore($dbManager);
            $consumer = new Consumer(
                db: $dbManager,
                idempotencyStore: $idempotencyStore,
                consumerGroup: $config->get('queue.consumer_group', 'sf_workers'),
                maxAttempts: (int) $config->get('queue.retry.max_attempts', 3),
                backoff: $config->get('queue.retry.backoff', [1, 5, 30]),
            );

            // Load app-level job handlers via a worker bootstrap (if exists)
            $workerBootstrap = $basePath . '/bootstrap/worker.php';
            if (is_file($workerBootstrap)) {
                (require $workerBootstrap)($consumer, $dbManager);
            }

            // Also start event consumers
            $eventConsumer = new EventConsumer(
                db: $dbManager,
                consumerGroup: $config->get('events.consumer_group', 'sf_consumers'),
            );

            $eventBootstrap = $basePath . '/bootstrap/events.php';
            if (is_file($eventBootstrap)) {
                (require $eventBootstrap)($eventConsumer, $dbManager);
            }

            echo "[Fabriq] Worker starting on queue 'default'...\n";

            // Run event consumer in parallel coroutine
            \Swoole\Coroutine::create(function () use ($eventConsumer) {
                $eventConsumer->consume();
            });

            // Run queue consumer (blocks)
            $consumer->consume('default');
        });
        break;

    case 'scheduler':
        echo "╔══════════════════════════════════════╗\n";
        echo "║              Fabriq                  ║\n";
        echo "║            Scheduler                 ║\n";
        echo "╚══════════════════════════════════════╝\n\n";

        $basePath = dirname(__DIR__);
        $config = Config::fromDirectory($basePath . '/config');
        $dbManager = new DbManager();

        \Swoole\Coroutine\run(function () use ($config, $dbManager, $basePath) {
            $dbManager->boot($config);

            $scheduler = new Scheduler(
                db: $dbManager,
                pollInterval: 1.0,
            );

            // Load scheduled jobs via bootstrap
            $schedBootstrap = $basePath . '/bootstrap/scheduler.php';
            if (is_file($schedBootstrap)) {
                (require $schedBootstrap)($scheduler, $dbManager);
            }

            echo "[Fabriq] Scheduler started (polling every 1s)...\n";
            $scheduler->start();

            // Keep the coroutine alive
            while (true) {
                \Swoole\Coroutine::sleep(60.0);
            }
        });
        break;

    case 'help':
    default:
        echo "Fabriq CLI\n\n";
        echo "Usage:\n";
        echo "  php bin/fabriq <command>\n\n";
        echo "Commands:\n";
        echo "  serve       Start HTTP + WebSocket server\n";
        echo "  worker      Start queue consumer workers\n";
        echo "  scheduler   Start cron-like scheduler\n";
        echo "  help        Show this help message\n\n";
        echo "Examples:\n";
        echo "  php bin/fabriq serve\n";
        echo "  php bin/fabriq worker\n";
        echo "  php bin/fabriq scheduler\n";
        break;
}

