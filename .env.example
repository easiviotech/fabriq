# SwooleFabric Environment Configuration
# Copy this to .env and fill in values

# Server
SWOOLE_FABRIC_ENV=local
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=2
SERVER_TASK_WORKERS=2

# MySQL — Platform DB
DB_PLATFORM_HOST=mysql
DB_PLATFORM_PORT=3306
DB_PLATFORM_DATABASE=sf_platform
DB_PLATFORM_USERNAME=swoolefabric
DB_PLATFORM_PASSWORD=sfpass

# MySQL — App DB
DB_APP_HOST=mysql
DB_APP_PORT=3306
DB_APP_DATABASE=sf_app
DB_APP_USERNAME=swoolefabric
DB_APP_PASSWORD=sfpass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Auth
JWT_SECRET=change-me-in-production
JWT_TTL=3600

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60
